#!/usr/bin/env bash
# Fake sound-server binary (pipewire/pulseaudio/jackd) for hardware-free tests.
# Reports "present" (exit 0) only when $FAKE_DEV_DIR/<name>_present exists, so
# detectSoundSystemType() can be steered; otherwise exits non-zero (absent).
set -u
name="$(basename "$0")"
if [[ -n "${FAKE_DEV_DIR:-}" && -f "${FAKE_DEV_DIR}/${name}_present" ]]; then
	echo "${name} (fake) 1.0.0"
	exit 0
fi
exit 1
